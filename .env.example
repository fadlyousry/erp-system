# Environment variables for Sales Manager Desktop
# Copy this file to .env and update with your settings

# ═══════════════════════════════════════════════════════════════
# DATABASE CONNECTION
# ═══════════════════════════════════════════════════════════════

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://erp_user:erp_secure_pass@localhost:5432/erp_clothing"

# ═══════════════════════════════════════════════════════════════
# POSTGRESQL SETTINGS (for bundled installation)
# ═══════════════════════════════════════════════════════════════

# PostgreSQL superuser credentials
ERP_PG_SUPER_USER="postgres"
ERP_PG_SUPER_PASSWORD="StrongPass123!"

# PostgreSQL service configuration
ERP_PG_SERVICE_NAME="postgresql-erp-16"
ERP_PG_PORT="5432"

# Installation mode: "bundled" for packaged app, "download" for development
ERP_PG_INSTALL_MODE="download"

# PostgreSQL installer file (must be in vendor/ directory)
ERP_PG_INSTALLER_FILE="postgresql-16.4-1-windows-x64.exe"
ERP_PG_INSTALLER_URL="https://get.enterprisedb.com/postgresql/postgresql-16.4-1-windows-x64.exe"

# ═══════════════════════════════════════════════════════════════
# DATABASE CREDENTIALS
# ═══════════════════════════════════════════════════════════════

# Application database name
ERP_DB_NAME="erp_clothing"

# Application database user
ERP_DB_USER="erp_user"

# Application database password
ERP_DB_PASSWORD="erp_secure_pass"

# ═══════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════

# JWT Secret for authentication (CHANGE THIS IN PRODUCTION!)
JWT_SECRET="your-secret-key-change-in-production-12345"

# Node environment
NODE_ENV="development"

# ═══════════════════════════════════════════════════════════════
# DEFAULT ADMIN CREDENTIALS (for first-time setup)
# ═══════════════════════════════════════════════════════════════

# Default admin username (created on first run)
ERP_DEFAULT_ADMIN_USERNAME="admin"

# Default admin password (created on first run)
ERP_DEFAULT_ADMIN_PASSWORD="123456"

# Default admin display name
ERP_DEFAULT_ADMIN_NAME="مدير النظام"

# ═══════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════

# 1. For development:
#    - Install PostgreSQL 16 manually
#    - Create database and user matching the credentials above
#    - Run: npm run prisma:migrate:dev
#    - Run: npm run prisma:bootstrap

# 2. For production (packaged app):
#    - PostgreSQL will be installed automatically
#    - Database will be created automatically
#    - Migrations will run automatically

# 3. Security:
#    - NEVER commit .env file to git
#    - Change JWT_SECRET in production
#    - Use strong passwords for PostgreSQL
#    - Keep ERP_PG_SUPER_PASSWORD secure

# 4. Ports:
#    - Default PostgreSQL port: 5432
#    - If port is in use, change ERP_PG_PORT
#    - Vite dev server: 5173 (automatic)
